const A: i64 = 1;
const B = A + 1;
const I: i32 = 4;

fn typed_const_index() -> i32 {
    let arr = [3]i32{10, 20, 30};
    return arr[B];
}

fn const_oob_index() -> i32 {
    let arr = [4]i32{1, 2, 3, 4};
    return arr[I];
}

fn main() -> i32 {
    return typed_const_index() + const_oob_index();
}
