#[no_copy]
//#[no_copy]
struct Buffer {
    value: i32
}

/// distroys everything
/// and
/// does nothing
// doc comments needs to snap on to the next decl node, should merge all previous doc comments lines even if have gaps
fn destroy(move _: Buffer) {}

fn main() -> i32 {
    let mut current: Buffer = .{ value = 1 };
    let mut next = move current;
    let ptr = @next;
    next.value = 2;
    ptr.value = 4;
    //let another = current;

    if next.value == ptr.value {
        return 69;
    }

    destroy(next);

    return 0;
}
